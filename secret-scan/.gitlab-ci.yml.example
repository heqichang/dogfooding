stages:
  - test
  - security

secret_scan:
  stage: security
  image: python:3.10-slim
  before_script:
    - pip install --upgrade pip
    - pip install git+https://github.com/your-org/secret-scan.git@main
    # Or install from local:
    # - pip install .
  script:
    - |
      if [ "$CI_PIPELINE_SOURCE" = "merge_request_event" ]; then
        echo "Running in Merge Request pipeline"
        # Scan the diff between source and target branch
        secret-scan scan --diff $CI_MERGE_REQUEST_DIFF_BASE_SHA..$CI_COMMIT_SHA --json report.json
      else
        echo "Running in branch pipeline"
        # Full scan on push to main branch
        secret-scan scan --full --json report.json
      fi
  artifacts:
    name: "secret-scan-report"
    paths:
      - report.json
    when: always
    expire_in: 30 days
  allow_failure: false  # Set to true to not block pipeline

secret_scan_warning:
  stage: security
  image: python:3.10-slim
  before_script:
    - pip install --upgrade pip
    - pip install git+https://github.com/your-org/secret-scan.git@main
  script:
    - secret-scan scan --full --no-fail --json report-warning.json
  artifacts:
    name: "secret-scan-report-warning"
    paths:
      - report-warning.json
    when: always
    expire_in: 30 days
  allow_failure: true  # This job will not block the pipeline
  rules:
    - if: $CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH
